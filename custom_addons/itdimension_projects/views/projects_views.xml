<odoo>
    <record id="project_list_view_form" model="ir.ui.view">
        <field name="name">project.list.form</field>
        <field name="model">project.list</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="name"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="project_list_viem_list" model="ir.ui.view">
        <field name="name">project.list.list</field>
        <field name="model">project.list</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_project_list" model="ir.actions.act_window">
        <field name="name">Project list</field>
        <field name="res_model">project.list</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_projects_root"
              name = "Projects"/>

    <menuitem id="menu_projects_configuration"
              name="Configuration"
              parent="menu_projects_root"
              sequence="100"/>

    <menuitem id="menu_project_list"
              name="Project list"
              action="action_project_list"
              parent="menu_projects_configuration"/>
</odoo>