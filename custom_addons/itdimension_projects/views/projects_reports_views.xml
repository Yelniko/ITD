<odoo>
    <record id="project_report_view_form" model="ir.ui.view">
        <field name="name">project.report.form</field>
        <field name="model">project.report</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="date"/>
                        <field name="name_developer"/>
                        <field name="name_project"/>
                        <field name="task"/>
                        <field name="logged" widget="float_time"/>
                        <field name="status"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Save"
                            type="object"
                            class="btn-primary"/>
                    <button string="End"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="project_report_view_search" model="ir.ui.view">
        <field name="name">project.report.search</field>
        <field name="model">project.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="name_project" string="Project"/>
                <field name="name_developer" string="Developer"/>
                <filter string="Date" name="filter_date" date="date"/>

                <separator/>
                <filter string="Group by Project"
                        name="group_project"
                        context="{'group_by': 'name_project'}"/>
                <filter string="Group by Developer"
                        name="group_developer"
                        context="{'group_by': 'name_developer'}"/>
            </search>
        </field>
    </record>

    <record id="project_report_viem_list" model="ir.ui.view">
        <field name="name">project.report.list</field>
        <field name="model">project.report</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="date"/>
                <field name="name_developer"/>
                <field name="name_project"/>
                <field name="task"/>
                <field name="logged" widget="float_time"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="action_project_report" model="ir.actions.act_window">
        <field name="name">Project report</field>
        <field name="res_model">project.report</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_project_report"
              name="Project report"
              action="action_project_report"
              parent="menu_projects_root"/>
</odoo>