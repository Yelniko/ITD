<odoo>
    <record id="key_framework_view_form" model="ir.ui.view">
        <field name="name">key.framework.form</field>
        <field name="model">key.framework</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="name"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="key_framework_viem_list" model="ir.ui.view">
        <field name="name">key.framework.list</field>
        <field name="model">key.framework</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_key_framework" model="ir.actions.act_window">
        <field name="name">Key framework</field>
        <field name="res_model">key.framework</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_key_framework"
              name="Key framework"
              action="action_key_framework"
              parent="hr.menu_hr_root"/>
</odoo>