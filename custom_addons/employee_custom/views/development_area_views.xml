<odoo>
    <record id="development_area_view_form" model="ir.ui.view">
        <field name="name">development.area.form</field>
        <field name="model">development.area</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="name"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="development_area_viem_list" model="ir.ui.view">
        <field name="name">development.area.list</field>
        <field name="model">development.area</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_development_area" model="ir.actions.act_window">
        <field name="name">Development area</field>
        <field name="res_model">development.area</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_development_area"
              name="Development area"
              action="action_development_area"
              parent="hr.hr_menu_configuration"/>
</odoo>