        </record>
        <record id="config_status_map" model="ir.config_parameter">
            <field name="key">migration.status_map</field>
            <field name="value">{"Работает": "available", "Не работает": "unavailable", "В отпуске": "on_vacation", "Завершил Проект": "project_completed"}</field>
        </record>
        <record id="config_status_map_report" model="ir.config_parameter">
            <field name="key">migration.status_map_report</field>
            <field name="value">{"In progress": "in_progress", "Done": "done", "-": "not_info", "": "not_info"}</field>
        </record>
        <record id="config_scopes" model="ir.config_parameter">
            <field name="key">migration.scopes</field>
            <field name="value">https://www.googleapis.com/auth/spreadsheets.readonly</field>
        </record>
