<odoo>
    <data noupdate="1">
        <record id="config_service_account_file" model="ir.config_parameter">
            <field name="key">migration.service_account_file</field>
            <field name="value">CHANGE_ME</field>
        </record>

        <record id="config_spreadsheet_employees_id" model="ir.config_parameter">
            <field name="key">migration.spreadsheet_employees_id</field>
            <field name="value">CHANGE_ME</field>
        </record>
        <record id="config_spreadsheet_birthdays_id" model="ir.config_parameter">
            <field name="key">migration.spreadsheet_birthdays_id</field>
            <field name="value">CHANGE_ME</field>
        </record>
        <record id="config_spreadsheet_working_hours_id" model="ir.config_parameter">
            <field name="key">migration.spreadsheet_working_hours_id</field>
            <field name="value">CHANGE_ME</field>
        </record>
        <record id="config_spreadsheet_projects_id" model="ir.config_parameter">
            <field name="key">migration.projects_id</field>
            <field name="value">CHANGE_ME</field>
        </record>
        <record id="config_spreadsheet_reports_id" model="ir.config_parameter">
            <field name="key">migration.spreadsheet_reports_id</field>
            <field name="value">CHANGE_ME</field>
        </record>
        <record id="config_spreadsheet_employees_sheet" model="ir.config_parameter">
            <field name="key">migration.spreadsheet_employees_sheet</field>
            <field name="value">employees_list</field>
        </record>
         <record id="config_spreadsheet_birthdays_sheet" model="ir.config_parameter">
            <field name="key">migration.spreadsheet_birthdays_sheet</field>
