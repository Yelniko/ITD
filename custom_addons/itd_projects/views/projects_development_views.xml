<odoo>
    <record id="project_development_view_form" model="ir.ui.view">
        <field name="name">project.development.form</field>
        <field name="model">project.development</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name_project"/>
                        <field name="name_developer"/>
                        <field name="status"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Save"
                            type="object"
                            class="btn-primary"/>
                    <button string="End"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="project_development_view_search" model="ir.ui.view">
        <field name="name">project.development.search</field>
        <field name="model">project.development</field>
        <field name="arch" type="xml">
            <search>
                <field name="name_project" string="Project"/>
                <field name="name_developer" string="Developer"/>

                <filter string="Group by Project"
                        name="group_project"
                        context="{'group_by': 'name_project'}"/>
                <filter string="Group by Developer"
                        name="group_developer"
                        context="{'group_by': 'name_developer'}"/>
            </search>
        </field>
    </record>

    <record id="project_development_viem_list" model="ir.ui.view">
        <field name="name">project.development.list</field>
        <field name="model">project.development</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name_project"/>
                <field name="name_developer"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="action_project_development" model="ir.actions.act_window">
        <field name="name">Project development</field>
        <field name="res_model">project.development</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_project_development"
              name="Project and development"
              action="action_project_development"
              parent="menu_projects_root"/>
</odoo>